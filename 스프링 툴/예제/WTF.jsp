			</select></td>
		</tr>
		<tr> <!--3행(이름|텍스트 에어리어)-->
			
		</tr>
		<tr> <!--4행(아디|텍.에)-->
			
		</tr>
		<tr> <!--5행(비번|텍.에)-->
			
		</tr>
		<tr> <!--6행(레전드(성별조사),인풋 타입 라디오)-->
			
		</tr>
		<tr> <!--7행(레전드(취미 조사),인풋 타입 체크박스)-->
			
		</tr>
		<tr> <!--8행(레전드(하고픈말),텍.에)-->
			
		</tr>
		<tr> <!--9행(완료(인풋 타입 서밋),다시 작성(인풋 타입 중 하나.))-->
			
		</tr>
	</table>
</body>
</html>