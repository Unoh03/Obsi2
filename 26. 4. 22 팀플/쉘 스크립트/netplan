sudo tee /etc/netplan/50-cloud-init.yaml > /dev/null << EOF
network:
  version: 2
  ethernets:
    ens33:
      dhcp4: true
      dhcp6: false
      routes:
        - to: default
          via: 192.168.33.1
    ens37:
      dhcp4: false
      dhcp6: false
      addresses:
        - 192.168.2.1/24
      routes:
        - to: default
          via: 192.168.2.254 
      nameservers:
        addresses:
          - 1.2.1.10
EOF

sudo chmod 600 /etc/netplan/50-cloud-init.yaml
sudo netplan apply